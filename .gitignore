# macOS
.DS_Store

# Auto-generated by scripts/build-stimuli.js on npm start
stimuli.json

# Audio files are gitignored by default (can be large).
# Uncomment the lines below to commit specific stimuli files:
# !audio/000000.wav
# !audio/000034.wav
# !audio/000040.wav
# !audio/000041.wav
# !audio/000042.wav
audio/*.wav
audio/*.mp3
audio/*.ogg
audio/*.flac

# Keep the folder tracked
!audio/.gitkeep
